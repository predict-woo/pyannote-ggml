{
  "name": "pyannote-cpp-node",
  "version": "0.3.0",
  "description": "Node.js bindings for whisper.cpp plus the pyannote speaker diarization pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "optionalDependencies": {
    "@pyannote-cpp-node/darwin-arm64": "0.3.0",
    "@pyannote-cpp-node/win32-x64": "0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.7.0"
  }
}
